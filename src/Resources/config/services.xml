<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true"/>

        <service id="VvWhatsAppAssistant\Controller\WhatsAppWebhookController" public="true">
            <tag name="controller.service_arguments"/>
        </service>

        <service id="VvWhatsAppAssistant\Service\BotReplyService"/>
        <service id="VvWhatsAppAssistant\Service\MessageLogService"/>
        <service id="VvWhatsAppAssistant\Service\WhatsAppMessageSender"/>
    </services>
</container>
