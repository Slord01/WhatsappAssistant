<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/platform/trunk/src/Core/System/SystemConfig/Schema/config.xsd">
    <card>
        <title lang="de-DE">FlowHunt WhatsApp Chat</title>
        <title lang="en-GB">FlowHunt WhatsApp Chat</title>

        <input-field type="bool">
            <name>enabled</name>
            <label lang="de-DE">FlowHunt WhatsApp Chat aktivieren</label>
            <label lang="en-GB">Enable FlowHunt WhatsApp chat</label>
            <defaultValue>false</defaultValue>
        </input-field>

        <component name="sw-entity-multi-id-select">
            <name>salesChannelIds</name>
            <entity>sales_channel</entity>
            <label lang="de-DE">Aktive Verkaufskanäle</label>
            <label lang="en-GB">Active sales channels</label>
            <helpText lang="de-DE">Wenn kein Verkaufskanal ausgewählt ist, wird der Button in allen Verkaufskanälen angezeigt.</helpText>
            <helpText lang="en-GB">If no sales channel is selected, the button is shown in all sales channels.</helpText>
        </component>

        <input-field type="text">
            <name>flowhuntChatUrl</name>
            <label lang="de-DE">FlowHunt Chat URL</label>
            <label lang="en-GB">FlowHunt chat URL</label>
            <placeholder>https://...</placeholder>
        </input-field>

        <input-field type="text">
            <name>buttonAriaLabel</name>
            <label lang="de-DE">Button-Beschriftung für Screenreader</label>
            <label lang="en-GB">Button label for screen readers</label>
            <defaultValue>WhatsApp Chat öffnen</defaultValue>
        </input-field>

        <input-field type="int">
            <name>bottomOffset</name>
            <label lang="de-DE">Abstand von unten in Pixel</label>
            <label lang="en-GB">Bottom offset in pixels</label>
            <defaultValue>96</defaultValue>
        </input-field>
    </card>
</config>
