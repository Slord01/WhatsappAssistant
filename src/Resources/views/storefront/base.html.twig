{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_body_script %}
    {{ parent() }}

    {% set vvConfigPrefix = 'VvWhatsAppAssistant.config.' %}
    {% set vvWhatsAppEnabled = config(vvConfigPrefix ~ 'enabled') %}
    {% set vvFlowhuntChatUrl = config(vvConfigPrefix ~ 'flowhuntChatUrl') %}
    {% set vvSelectedSalesChannels = config(vvConfigPrefix ~ 'salesChannelIds') ?: [] %}
    {% set vvCurrentSalesChannelId = context.salesChannel.id|default(null) %}
    {% set vvEnabledForSalesChannel = vvSelectedSalesChannels is empty or vvCurrentSalesChannelId in vvSelectedSalesChannels %}

    {% if vvWhatsAppEnabled and vvFlowhuntChatUrl and vvEnabledForSalesChannel %}
        {% set vvButtonAriaLabel = config(vvConfigPrefix ~ 'buttonAriaLabel') ?: 'WhatsApp Chat öffnen' %}
        {% set vvBottomOffset = config(vvConfigPrefix ~ 'bottomOffset') ?: 96 %}

        <div class="vv-whatsapp-assistant"
             data-vv-flowhunt-chat
             style="--vv-whatsapp-assistant-bottom: {{ vvBottomOffset|abs }}px;">
        <button class="vv-whatsapp-assistant-button"
                type="button"
                aria-label="{{ vvButtonAriaLabel }}"
                aria-expanded="false"
                aria-controls="vv-whatsapp-assistant-panel">
            <svg class="vv-whatsapp-assistant-button__icon"
                 xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 32 32"
                 focusable="false"
                 aria-hidden="true">
                <path fill="currentColor" d="M16.02 4C9.41 4 4.03 9.34 4.03 15.91c0 2.11.56 4.16 1.62 5.96L4 28l6.3-1.64a12.1 12.1 0 0 0 5.72 1.45C22.63 27.81 28 22.47 28 15.9S22.63 4 16.02 4Zm0 21.78c-1.8 0-3.55-.48-5.08-1.38l-.36-.21-3.74.97 1-3.63-.24-.37a9.82 9.82 0 0 1-1.53-5.25c0-5.45 4.47-9.88 9.96-9.88s9.95 4.43 9.95 9.88-4.47 9.87-9.96 9.87Zm5.46-7.39c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.4-1.47a8.94 8.94 0 0 1-1.66-2.06c-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.6-.91-2.19-.24-.57-.49-.5-.67-.5h-.57c-.2 0-.52.08-.79.38-.27.3-1.04 1.01-1.04 2.46s1.07 2.86 1.22 3.06c.15.2 2.11 3.2 5.1 4.49.71.3 1.27.49 1.7.62.71.23 1.36.2 1.88.12.57-.08 1.77-.72 2.02-1.42.25-.7.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35Z"/>
            </svg>
        </button>

        <section class="vv-whatsapp-assistant-panel"
                 id="vv-whatsapp-assistant-panel"
                 aria-label="FlowHunt WhatsApp Chat"
                 hidden>
            <div class="vv-whatsapp-assistant-panel__header">
                <span>WhatsApp Chat</span>
                <button class="vv-whatsapp-assistant-panel__close"
                        type="button"
                        aria-label="Chat schließen">
                    &times;
                </button>
            </div>
            <iframe class="vv-whatsapp-assistant-panel__frame"
                    src="{{ vvFlowhuntChatUrl }}"
                    title="FlowHunt WhatsApp Chat"
                    loading="lazy"
                    referrerpolicy="strict-origin-when-cross-origin"></iframe>
            <a class="vv-whatsapp-assistant-panel__fallback"
               href="{{ vvFlowhuntChatUrl }}"
               target="_blank"
               rel="noopener noreferrer">
                Chat in neuem Fenster öffnen
            </a>
        </section>
        </div>

        <style>
            .vv-whatsapp-assistant {
                position: fixed;
                right: 18px;
                bottom: var(--vv-whatsapp-assistant-bottom, 96px);
                z-index: 2147483000;
            }

            .vv-whatsapp-assistant-button {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 54px;
                height: 54px;
                padding: 0;
                border: 0;
                border-radius: 50%;
                background: #25d366;
                color: #ffffff;
                cursor: pointer;
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.22);
                transition: transform 0.16s ease, background-color 0.16s ease, box-shadow 0.16s ease;
            }

            .vv-whatsapp-assistant-button:hover,
            .vv-whatsapp-assistant-button:focus {
                color: #ffffff;
                background: #1fbd5b;
                text-decoration: none;
                transform: translateY(-1px);
                box-shadow: 0 10px 24px rgba(0, 0, 0, 0.24);
            }

            .vv-whatsapp-assistant-button:focus-visible {
                outline: 3px solid rgba(37, 211, 102, 0.35);
                outline-offset: 3px;
            }

            .vv-whatsapp-assistant-button__icon {
                width: 32px;
                height: 32px;
                display: block;
            }

            .vv-whatsapp-assistant-panel {
                position: absolute;
                right: 0;
                bottom: 66px;
                width: min(380px, calc(100vw - 24px));
                height: min(620px, calc(100vh - var(--vv-whatsapp-assistant-bottom, 96px) - 88px));
                min-height: 420px;
                overflow: hidden;
                border: 1px solid rgba(0, 0, 0, 0.12);
                border-radius: 8px;
                background: #ffffff;
                box-shadow: 0 16px 44px rgba(0, 0, 0, 0.24);
            }

            .vv-whatsapp-assistant-panel__header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                height: 46px;
                padding: 0 12px 0 16px;
                background: #128c7e;
                color: #ffffff;
                font-size: 15px;
                font-weight: 700;
            }

            .vv-whatsapp-assistant-panel__close {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 34px;
                height: 34px;
                padding: 0;
                border: 0;
                border-radius: 50%;
                background: transparent;
                color: #ffffff;
                cursor: pointer;
                font-size: 24px;
                line-height: 1;
            }

            .vv-whatsapp-assistant-panel__close:hover,
            .vv-whatsapp-assistant-panel__close:focus {
                background: rgba(255, 255, 255, 0.14);
            }

            .vv-whatsapp-assistant-panel__frame {
                display: block;
                width: 100%;
                height: calc(100% - 84px);
                border: 0;
            }

            .vv-whatsapp-assistant-panel__fallback {
                display: block;
                margin: 8px 12px;
                padding: 10px 12px;
                border-radius: 6px;
                background: #25d366;
                color: #ffffff;
                font-size: 14px;
                font-weight: 700;
                text-align: center;
                text-decoration: none;
            }

            @media (max-width: 575.98px) {
                .vv-whatsapp-assistant {
                    right: 12px;
                }

                .vv-whatsapp-assistant-button {
                    width: 50px;
                    height: 50px;
                }

                .vv-whatsapp-assistant-button__icon {
                    width: 30px;
                    height: 30px;
                }

                .vv-whatsapp-assistant-panel {
                    bottom: 62px;
                    width: calc(100vw - 24px);
                    height: min(620px, calc(100vh - var(--vv-whatsapp-assistant-bottom, 96px) - 82px));
                    min-height: 360px;
                }
            }
        </style>

        <script>
            (() => {
                const root = document.querySelector('[data-vv-flowhunt-chat]');

                if (!root) {
                    return;
                }

                const button = root.querySelector('.vv-whatsapp-assistant-button');
                const panel = root.querySelector('.vv-whatsapp-assistant-panel');
                const close = root.querySelector('.vv-whatsapp-assistant-panel__close');

                if (!button || !panel || !close) {
                    return;
                }

                const setOpen = (isOpen) => {
                    panel.hidden = !isOpen;
                    button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                };

                button.addEventListener('click', () => {
                    setOpen(panel.hidden);
                });

                close.addEventListener('click', () => {
                    setOpen(false);
                    button.focus();
                });

                document.addEventListener('keydown', (event) => {
                    if (event.key === 'Escape') {
                        setOpen(false);
                    }
                });
            })();
        </script>
    {% endif %}
{% endblock %}
